# HopMap Server — secrets and optional integrations
# Full config lives in server_config.json; only secrets belong here.
# Copy this file to .env and fill in the values.

# NVIDIA NIM API key — required when LLM_PROVIDER=nvidia
# Get yours at: https://build.nvidia.com
HOPMAP_SERVER__LLM__API_KEY=

# MongoDB connection URI
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hopmap
HOPMAP_SERVER__DB__MONGO_URI=mongodb://localhost:27017

# JWT signing secret — required in production (min 32 chars recommended)
# HOPMAP_SERVER__AUTH__JWT_SECRET=

# Email — password reset (optional — leave ENABLED blank/unset to disable)
# 1. Set SMTP_USER and SMTP_PASSWORD (for Gmail, use an App Password)
# 2. Set RESET_PASSWORD_URL to your frontend origin (e.g. https://app.hopmap.io)
# 3. Flip ENABLED to true
HOPMAP_SERVER__EMAIL__ENABLED=false
HOPMAP_SERVER__EMAIL__SMTP_USER=
HOPMAP_SERVER__EMAIL__SMTP_PASSWORD=
HOPMAP_SERVER__EMAIL__RESET_PASSWORD_URL=http://localhost:5173

# Allowed CORS origins — must be a valid JSON array (pydantic-settings parses it as JSON).
# Required when using credentials (cookies). "*" is NOT allowed with allow_credentials=True.
# Example: ["https://hop-map-repo.vercel.app","http://localhost:5173"]
HOPMAP_SERVER__NETWORK__CORS_ORIGINS=["http://localhost:5173"]

# Telegram bot notifications (optional — leave blank to disable)
# 1. Create a bot at t.me/BotFather
# 2. Set the three values below
# 3. Register the webhook once: POST https://api.telegram.org/bot<TOKEN>/setWebhook
#    with {"url":"https://your-server/telegram/webhook","secret_token":"<WEBHOOK_SECRET>"}
HOPMAP_SERVER__TELEGRAM__BOT_TOKEN=
HOPMAP_SERVER__TELEGRAM__BOT_USERNAME=
HOPMAP_SERVER__TELEGRAM__WEBHOOK_SECRET=
