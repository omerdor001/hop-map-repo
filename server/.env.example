# ── HopMap SERVER secrets ─────────────────────────────────────────────────────
# This file contains SECRETS ONLY. Operational config lives in server_config.json.
# Copy this to .env, fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection URI — the only secret the server needs.
# Local Compass (dev):  mongodb://localhost:27017
# Atlas (production):   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hopmap?retryWrites=true&w=majority
HOPMAP_SERVER__DB__MONGO_URI=mongodb://localhost:27017
