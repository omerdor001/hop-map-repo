{
  "network": {
    "host": "0.0.0.0",
    "port": 8000,
    "cors_origins": ["*"]
  },
  "db": {
    "db_name": "hopmap",
    "events_collection": "events",
    "rules_collection": "rules",
    "words_collection": "words",
    "words_refresh_interval_seconds": 3600
  },
  "llm": {
    "provider": "ollama",
    "model": "qwen2.5:7b"
  },
  "auth": {
    "jwt_secret": "change-me-in-production",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 15,
    "refresh_token_expire_days": 30,
    "refresh_cookie_name": "hopmap_refresh",
    "refresh_cookie_secure": false
  },
  "classify_max_rpm": 30,
  "classify_context_max_chars": 2000,
  "demo_mode": false
}
