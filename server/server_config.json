{
  "network": {
    "host": "0.0.0.0",
    "port": 8000,
    "cors_origins": ["*"],
    "workers": 1
  },
  "db": {
    "db_name": "hopmap",
    "events_collection": "events",
    "rules_collection": "rules",
    "words_collection": "words",
    "words_refresh_interval_seconds": 3600
  },
  "llm": {
    "provider": "nvidia",
    "model": "moonshotai/kimi-k2.6"
  },
  "auth": {
    "jwt_secret": "change-me-in-production",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 15,
    "refresh_token_expire_days": 30,
    "refresh_cookie_name": "hopmap_refresh",
    "refresh_cookie_secure": false
  },
  "email": {
    "enabled": false,
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "smtp_secure": false,
    "from_name": "HopeMap",
    "reset_token_expiry_minutes": 30,
    "reset_password_url": "http://localhost:5173"
  },
  "classify_max_rpm": 30,
  "classify_context_max_chars": 2000,
  "demo_mode": false
}
