{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "dashboard/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "src": "/auth/(.*)",     "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "src": "/stream/(.*)",   "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "src": "/agent/(.*)",    "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "src": "/health/(.*)",   "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "src": "/telegram/(.*)", "dest": "/api/index.py", "methods": ["GET","POST","PUT","DELETE","PATCH","OPTIONS"] },
    { "handle": "filesystem" },
    { "src": "/(.*)",          "dest": "/dashboard/index.html" }
  ]
}
