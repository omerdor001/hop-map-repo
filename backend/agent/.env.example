# HopMap Agent Configuration
# Copy this file to .env on the kid's Windows PC, then run agent.py
# ---------------------------------------------------------

# Where the HopMap server is running
BACKEND_URL=http://localhost:8000

# Ollama model used for classification (if using local fallback)
OLLAMA_MODEL=qwen2.5:7b

# How often (in seconds) to OCR-scan the game window for links
SCAN_INTERVAL_SECONDS=5

# How many chat lines around a detected URL to send to Ollama for context
CONTEXT_LINES=10

# Path to Excel file containing platform process mappings
# REQUIRED: Must point to an Excel file with columns "platform" and "process"
# Example: C:\Users\alex\Documents\platforms.xlsx
PLATFORMS_DB_PATH="backend\agent\platform_db.xlsx"