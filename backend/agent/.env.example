# HopMap Agent — Environment Configuration
# Copy this file to .env and customize as needed

# Where the HopMap server is running
BACKEND_URL=http://localhost:8000

# Show a warning popup to the child when a hop is confirmed (grooming alert)
# Set to "false" to disable the child-facing alert
ENABLE_CHILD_ALERTS=true

# How often (in seconds) to OCR-scan the game window for links
# SCAN_INTERVAL_SECONDS=5

# How many chat lines around a detected URL to send to the server for context
# CONTEXT_LINES=10