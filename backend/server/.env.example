# ── HopMap SERVER config ──────────────────────────────────────────────────────
# Copy this file to .env on the SERVER machine, then run: python server.py
# ─────────────────────────────────────────────────────────────────────────────

# Network
HOST=0.0.0.0
PORT=8000

# CORS — which origins can connect to the server
# Dev:        CORS_ORIGINS=*
# Production: CORS_ORIGINS=https://your-dashboard.vercel.app
CORS_ORIGINS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: Local MongoDB Compass (dev / testing)
MONGO_URI=mongodb://localhost:27017

# Option B: MongoDB Atlas (hackathon demo / production)
# Uncomment and fill in your Atlas connection string:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hopmap?retryWrites=true&w=majority

DB_NAME=hopmap
EVENTS_COLLECTION=events
RULES_COLLECTION=rules

# ── Nasty Words Database ────────────────────────────────────────────────────
# Path to Excel file containing blocked words (minimizes LLM calls)
# The Excel file should have a column header "word" with words to flag
# Example: C:\Users\alex\Documents\nasty_words.xlsx
# Leave empty to disable word-based blocking (will use LLM only)
WORDS_DB_PATH="backend\server\hopmap_words_db.xlsx"
